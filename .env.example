# MinIO / S3 Configuration
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=fake-reviews
MINIO_SECURE=false

# Sentence Transformer Model
SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# HuggingFace — suppress "unauthenticated requests" warnings (no account needed)
HUGGINGFACE_HUB_VERBOSITY=error
# Optional: set HF_TOKEN for higher rate limits (requires account)
HF_TOKEN=

# Privacy controls for exported datasets
# Keep enabled for any files intended for sharing.
ANONYMIZE_EXPORTS=true
ANONYMIZATION_SALT=CHANGE_ME_RANDOM_SALT

# Jupyter access control
JUPYTER_TOKEN=CHANGE_ME_JUPYTER_TOKEN

# Prefect Configuration (optional)
PREFECT_API_URL=http://localhost:4200/api

# Database
DUCKDB_PATH=data/processed/reviews.duckdb
